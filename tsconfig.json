{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["bun-types", "node"]
  },
  "include": ["scripts/**/*.ts", "processes/impl-cli/**/*.ts"]
}
