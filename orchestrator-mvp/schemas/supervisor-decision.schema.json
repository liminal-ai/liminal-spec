{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "rationale", "useExceptionToken"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["approve", "rework", "escalate"]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "useExceptionToken": {
      "type": "boolean"
    },
    "note": {
      "type": "string"
    }
  }
}
