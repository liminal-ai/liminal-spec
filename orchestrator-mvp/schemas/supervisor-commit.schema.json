{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["committed", "no_changes", "failed"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
